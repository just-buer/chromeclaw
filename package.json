{
  "name": "chromeclaw-extension",
  "version": "1.8.0",
  "description": "ChromeClaw Chrome Extension",
  "license": "MIT",
  "private": true,
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/nicepkg/chromeclaw.git"
  },
  "type": "module",
  "scripts": {
    "clean:bundle": "rimraf dist && turbo clean:bundle",
    "clean:node_modules": "pnpx rimraf node_modules && pnpx turbo clean:node_modules",
    "clean:turbo": "rimraf .turbo && turbo clean:turbo",
    "clean": "pnpm clean:bundle && pnpm clean:turbo && pnpm clean:node_modules",
    "clean:install": "pnpm clean:node_modules && pnpm install --frozen-lockfile",
    "type-check": "turbo type-check",
    "base-build": "pnpm clean:bundle && turbo build",
    "build": "pnpm set-global-env && pnpm base-build",
    "build:firefox": "pnpm set-global-env CLI_CEB_FIREFOX=true && pnpm base-build",
    "base-dev": "pnpm clean:bundle && turbo ready && turbo watch dev",
    "dev": "pnpm set-global-env CLI_CEB_DEV=true && pnpm base-dev",
    "dev:firefox": "pnpm set-global-env CLI_CEB_DEV=true CLI_CEB_FIREFOX=true && pnpm base-dev",
    "zip": "pnpm build && pnpm -F zipper zip",
    "zip:firefox": "pnpm build:firefox && pnpm -F zipper zip",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "quality": "pnpm lint && pnpm format:check && pnpm type-check && pnpm test",
    "prepare": "husky",
    "update-version": "bash bash-scripts/update_version.sh",
    "copy-env": "bash bash-scripts/copy_env.sh",
    "set-global-env": "bash bash-scripts/set_global_env.sh",
    "module-manager": "pnpm -F module-manager start",
    "postinstall": "pnpm copy-env"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.13",
    "@mariozechner/pi-agent-core": "0.53.0",
    "@mariozechner/pi-ai": "0.53.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@sinclair/typebox": "^0.34.48",
    "@streamdown/mermaid": "^1.0.2",
    "@tailwindcss/typography": "^0.5.19",
    "@xyflow/react": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "codemirror": "^6.0.2",
    "date-fns": "^4.1.0",
    "dexie": "^4.3.0",
    "diff-match-patch": "^1.0.5",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.34.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.563.0",
    "motion": "^12.34.0",
    "nanoid": "^5.1.6",
    "orderedmap": "^2.1.1",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^3.11.174",
    "prosemirror-example-setup": "^1.2.3",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-markdown": "^1.13.4",
    "prosemirror-model": "^1.25.4",
    "prosemirror-schema-basic": "^1.2.4",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.6",
    "radix-ui": "^1.4.3",
    "react": "^19.1.0",
    "react-data-grid": "7.0.0-beta.59",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.7",
    "streamdown": "^2.2.0",
    "tailwind-merge": "^3.3.1",
    "use-stick-to-bottom": "^1.1.3",
    "usehooks-ts": "^3.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/compat": "^1.2.9",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@playwright/test": "^1.58.2",
    "@types/chrome": "^0.0.323",
    "@types/diff-match-patch": "^1.0.36",
    "@types/eslint-plugin-jsx-a11y": "^6.10.0",
    "@types/node": "^22.15.21",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "deepmerge": "^4.3.1",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.3.5",
    "eslint-plugin-import-x": "^4.12.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "eslint-plugin-tailwindcss": "^3.18.0",
    "fake-indexeddb": "^6.2.5",
    "fast-glob": "^3.3.3",
    "fflate": "^0.8.2",
    "globals": "^16.1.0",
    "husky": "^9.1.7",
    "jiti": "^2.4.2",
    "lint-staged": "^16.1.6",
    "postcss": "^8.5.3",
    "postcss-load-config": "^6.0.1",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "rimraf": "^6.0.1",
    "run-script-os": "^1.1.6",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tslib": "^2.8.1",
    "tsx": "^4.19.4",
    "turbo": "^2.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.43.0",
    "vite": "^6.3.6",
    "vite-plugin-node-polyfills": "^0.23.0",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22.15.1"
  }
}
